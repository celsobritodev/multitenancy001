                  "const pairs=JSON.parse(pm.collectionVariables.get('currentTenantSubPairs')||'[]');",
                  "const suppliers=JSON.parse(pm.collectionVariables.get('currentTenantSuppliers')||'[]');",
                  "const cat=cats[idx%cats.length], valid=pairs.filter(p=>p.categoryId===cat.id), sub=valid.length?valid[idx%valid.length]:null, sup=suppliers.length?suppliers[idx%suppliers.length]:null;",
                  "const schema=(pm.collectionVariables.get('currentTenantSchema')||'tenant').replace(/[^a-zA-Z0-9]/g,'').slice(-8);",
                  "pm.request.body.update(JSON.stringify({name:`Produto ${String(idx+1).padStart(2,'0')}`,sku:`SKU-${schema}-${String(idx+1).padStart(3,'0')}`,categoryId:cat.id,subcategoryId:sub?sub.id:null,supplierId:sup?sup.id:null,costPrice:10+idx,salePrice:20+idx,stockQuantity:0,minimumStock:1}));"
                ]
