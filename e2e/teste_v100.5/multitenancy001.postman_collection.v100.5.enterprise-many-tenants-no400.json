    {
      "name": "\ud83d\udce6 02 - CONTROL PLANE USERS GRID",
      "item": [
        {
          "name": "02.01 create control plane user grid",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let idx=parseInt(pm.collectionVariables.get('cpUserIdx')||'0',10);",
                  "const roles=['CONTROLPLANE_ADMIN','CONTROLPLANE_SUPPORT','CONTROLPLANE_VIEWER','CONTROLPLANE_OPERATOR','CONTROLPLANE_BILLING_MANAGER','CONTROLPLANE_SUPPORT'];",
                  "const perms={",
                  "CONTROLPLANE_ADMIN:['CP_USER_READ','CP_USER_WRITE','CP_BILLING_READ','CP_BILLING_WRITE','CP_TENANT_READ','CP_ME_READ'],",
                  "CONTROLPLANE_SUPPORT:['CP_USER_READ','CP_TENANT_READ','CP_ME_READ'],",
                  "CONTROLPLANE_VIEWER:['CP_USER_READ','CP_BILLING_READ','CP_TENANT_READ','CP_ME_READ'],",
                  "CONTROLPLANE_OPERATOR:['CP_USER_READ','CP_TENANT_READ','CP_ME_READ'],",
                  "CONTROLPLANE_BILLING_MANAGER:['CP_BILLING_READ','CP_BILLING_WRITE','CP_ME_READ']",
                  "};",
                  "const role=roles[idx%roles.length], s=String(idx+1).padStart(2,'0');",
                  "pm.request.body.update(JSON.stringify({name:`CP User ${s}`,email:`cp.user.${s}@example.com`,password:'Admin@123456',role:role,permissions:perms[role]}));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Control plane user grid request accepted',()=>pm.expect([201,409]).to.include(pm.response.code));",
                  "let idx=parseInt(pm.collectionVariables.get('cpUserIdx')||'0',10)+1;",
                  "pm.collectionVariables.set('cpUserIdx',String(idx));",
                  "pm.execution.setNextRequest(idx < parseInt(pm.collectionVariables.get('cpUserTarget')||'6',10) ? '02.01 create control plane user grid' : '03.01 create billing grid');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
