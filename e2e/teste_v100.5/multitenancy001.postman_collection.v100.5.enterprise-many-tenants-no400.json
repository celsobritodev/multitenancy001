            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Billing grid request accepted',()=>pm.expect([200,201,409]).to.include(pm.response.code));",
                  "let idx=parseInt(pm.collectionVariables.get('billingIdx')||'0',10)+1;",
                  "pm.collectionVariables.set('billingIdx',String(idx));",
                  "pm.execution.setNextRequest(idx < parseInt(pm.collectionVariables.get('billingTarget')||'60',10) ? '03.01 create billing grid' : '04.00 init current tenant context');"
