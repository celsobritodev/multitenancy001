              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const grid=JSON.parse(pm.collectionVariables.get('tenantGrid')||'[]');",
                  "let idx=parseInt(pm.collectionVariables.get('billingIdx')||'0',10);",
                  "const tenant=grid[idx%grid.length], slot=Math.floor(idx/grid.length)+1;",
                  "pm.request.body.update(JSON.stringify({accountId:tenant.accountId,externalReference:`PAY-${tenant.accountId}-${slot}`,amount:100+slot,description:`Seed payment ${slot}`,status:'CONFIRMED'}));"
                ]
