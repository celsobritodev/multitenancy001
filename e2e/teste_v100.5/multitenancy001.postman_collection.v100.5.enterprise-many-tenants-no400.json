                  "pm.test('Tenant loop init OK',()=>pm.response.to.have.status(200));",
                  "const grid=JSON.parse(pm.collectionVariables.get('tenantGrid')||'[]');",
                  "let tenantIdx=parseInt(pm.collectionVariables.get('tenantIdx')||'0',10);",
                  "if (tenantIdx >= grid.length) { pm.execution.setNextRequest('99.01 controlplane final accounts smoke'); }",
                  "else {",
                  "  const t=grid[tenantIdx];",
                  "  pm.collectionVariables.set('currentTenantSchema',t.tenantSchema);",
                  "  pm.collectionVariables.set('currentTenantAdminEmail',t.adminEmail);",
                  "  pm.collectionVariables.set('currentTenantAdminPassword',t.adminPassword);",
                  "  pm.collectionVariables.set('currentTenantCategories','[]');",
                  "  pm.collectionVariables.set('currentTenantSubPairs','[]');",
                  "  pm.collectionVariables.set('currentTenantSuppliers','[]');",
                  "  pm.collectionVariables.set('currentTenantCustomers','[]');",
                  "  pm.collectionVariables.set('currentTenantProducts','[]');",
