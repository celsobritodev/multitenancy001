              ]
            }
          },
          "response": []
        },
        {
          "name": "01.02 controlplane list accounts and capture tenant ids",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Control plane list accounts OK',()=>pm.response.to.have.status(200));",
                  "const j=pm.response.json();",
                  "const arr=Array.isArray(j)?j:(j.content||j.items||[]);",
                  "const grid=arr.filter(a => !a.controlPlane && !a.isControlPlane).slice(-parseInt(pm.collectionVariables.get('tenantTarget')||'20',10)).map((a,i)=>({",
                  "  accountId:a.id, tenantSchema:a.schemaName||a.tenantSchema||a.schema||'', adminEmail:a.adminEmail||`tenant${String(i+1).padStart(2,'0')}@example.com`, adminPassword:'Admin@123456'",
                  "}));",
                  "pm.collectionVariables.set('tenantGrid',JSON.stringify(grid));",
                  "pm.collectionVariables.set('tenantIdx','0');",
                  "pm.execution.setNextRequest('02.01 create control plane user grid');"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{cpToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/controlplane/accounts",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "controlplane",
                "accounts"
              ]
            }
          },
          "response": []
        }
