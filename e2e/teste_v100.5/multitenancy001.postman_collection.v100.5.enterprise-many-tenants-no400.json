        {
          "name": "01.01 signup tenant account grid",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let idx=parseInt(pm.collectionVariables.get('signupIdx')||'0',10);",
                  "let s=String(idx+1).padStart(2,'0');",
                  "pm.request.body.update(JSON.stringify({",
                  "  companyName:`Tenant Empresa ${s}`,",
                  "  workspaceName:`tenant-${s}`,",
                  "  adminName:`Tenant Admin ${s}`,",
                  "  adminEmail:`tenant${s}@example.com`,",
                  "  adminPassword:'Admin@123456'",
                  "}));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Signup tenant grid OK',()=>pm.response.to.have.status(201));",
                  "let idx=parseInt(pm.collectionVariables.get('signupIdx')||'0',10)+1;",
                  "pm.collectionVariables.set('signupIdx',String(idx));",
                  "pm.execution.setNextRequest(idx < parseInt(pm.collectionVariables.get('tenantTarget')||'20',10) ? '01.01 signup tenant account grid' : '01.02 controlplane list accounts and capture tenant ids');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
